<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" target-language="de" datatype="plaintext" original="messages" date="2024-01-01T00:00:00Z" product-name="sluggi">
        <header/>
        <body>
            <trans-unit id="conflict.title" resname="conflict.title">
                <source>URL Path Conflict</source>
                <target>URL-Pfad-Konflikt</target>
            </trans-unit>
            <trans-unit id="conflict.message" resname="conflict.message">
                <source>The URL path "%s" is already in use.</source>
                <target>Der URL-Pfad "%s" wird bereits verwendet.</target>
            </trans-unit>
            <trans-unit id="conflict.suggestion" resname="conflict.suggestion">
                <source>Use the suggested alternative "%s" instead?</source>
                <target>Stattdessen die vorgeschlagene Alternative "%s" verwenden?</target>
            </trans-unit>
            <trans-unit id="conflict.button.cancel" resname="conflict.button.cancel">
                <source>Cancel</source>
                <target>Abbrechen</target>
            </trans-unit>
            <trans-unit id="conflict.button.useSuggestion" resname="conflict.button.useSuggestion">
                <source>Use Suggestion</source>
                <target>Vorschlag verwenden</target>
            </trans-unit>
            <trans-unit id="pages.tx_sluggi_sync" resname="pages.tx_sluggi_sync">
                <source>Sluggi: Auto-sync URL path</source>
                <target>Sluggi: URL-Pfad automatisch synchronisieren</target>
            </trans-unit>
            <trans-unit id="pages.slug_locked" resname="pages.slug_locked">
                <source>Sluggi: Lock URL path</source>
                <target>Sluggi: URL-Pfad sperren</target>
            </trans-unit>
            <trans-unit id="restriction.sync" resname="restriction.sync">
                <source>The URL path is automatically synchronized with the source fields.</source>
                <target>Der URL-Pfad wird automatisch mit den Quellfeldern synchronisiert.</target>
            </trans-unit>
            <trans-unit id="restriction.lock" resname="restriction.lock">
                <source>The URL path is locked and cannot be edited.</source>
                <target>Der URL-Pfad ist gesperrt und kann nicht bearbeitet werden.</target>
            </trans-unit>
            <trans-unit id="pages.tx_sluggi_full_path" resname="pages.tx_sluggi_full_path">
                <source>Sluggi: Edit full path</source>
                <target>Sluggi: Vollständigen Pfad bearbeiten</target>
            </trans-unit>
            <trans-unit id="restriction.fullPath" resname="restriction.fullPath">
                <source>Full path editing is enabled. You can modify the entire URL structure.</source>
                <target>Vollständige Pfadbearbeitung ist aktiviert. Sie können die gesamte URL-Struktur ändern.</target>
            </trans-unit>
            <trans-unit id="button.edit" resname="button.edit">
                <source>Click to edit the URL path</source>
                <target>Klicken, um den URL-Pfad zu bearbeiten</target>
            </trans-unit>
            <trans-unit id="button.regenerate" resname="button.regenerate">
                <source>Regenerate URL path from source fields</source>
                <target>URL-Pfad aus Quellfeldern neu generieren</target>
            </trans-unit>
            <trans-unit id="button.cancel" resname="button.cancel">
                <source>Cancel editing</source>
                <target>Bearbeitung abbrechen</target>
            </trans-unit>
            <trans-unit id="button.save" resname="button.save">
                <source>Save URL path</source>
                <target>URL-Pfad speichern</target>
            </trans-unit>
            <trans-unit id="toggle.sync.on" resname="toggle.sync.on">
                <source>Auto-sync enabled: URL path updates with title</source>
                <target>Auto-Sync aktiviert: URL-Pfad wird mit Titel aktualisiert</target>
            </trans-unit>
            <trans-unit id="toggle.sync.off" resname="toggle.sync.off">
                <source>Auto-sync disabled: click to enable</source>
                <target>Auto-Sync deaktiviert: Klicken zum Aktivieren</target>
            </trans-unit>
            <trans-unit id="toggle.sync.static" resname="toggle.sync.static">
                <source>Auto-sync enabled: URL path updates automatically</source>
                <target>Auto-Sync aktiviert: URL-Pfad wird automatisch aktualisiert</target>
            </trans-unit>
            <trans-unit id="toggle.lock.on" resname="toggle.lock.on">
                <source>URL path is locked: click to unlock</source>
                <target>URL-Pfad ist gesperrt: Klicken zum Entsperren</target>
            </trans-unit>
            <trans-unit id="toggle.lock.off" resname="toggle.lock.off">
                <source>URL path is unlocked: click to lock</source>
                <target>URL-Pfad ist entsperrt: Klicken zum Sperren</target>
            </trans-unit>
            <trans-unit id="toggle.path.on" resname="toggle.path.on">
                <source>Full path editing enabled: click to restrict</source>
                <target>Vollständige Pfadbearbeitung aktiviert: Klicken zum Einschränken</target>
            </trans-unit>
            <trans-unit id="toggle.path.off" resname="toggle.path.off">
                <source>Click to edit full path</source>
                <target>Klicken, um vollständigen Pfad zu bearbeiten</target>
            </trans-unit>
            <trans-unit id="button.menu" resname="button.menu">
                <source>Toggle controls menu</source>
                <target>Steuerungsmenü ein-/ausblenden</target>
            </trans-unit>
            <trans-unit id="button.editFullPath" resname="button.editFullPath">
                <source>Edit full URL path</source>
                <target>Vollständigen URL-Pfad bearbeiten</target>
            </trans-unit>
            <trans-unit id="button.copyUrl" resname="button.copyUrl">
                <source>Copy page URL to clipboard</source>
                <target>Seiten-URL in Zwischenablage kopieren</target>
            </trans-unit>
            <trans-unit id="copyConfirmation" resname="copyConfirmation">
                <source>URL copied to clipboard.</source>
                <target>URL in Zwischenablage kopiert.</target>
            </trans-unit>
            <trans-unit id="openInNewTab" resname="openInNewTab">
                <source>Open in new tab</source>
                <target>In neuem Tab öffnen</target>
            </trans-unit>
            <trans-unit id="userSettings.collapsedControls" resname="userSettings.collapsedControls">
                <source>Sluggi: Use compact controls menu</source>
                <target>Sluggi: Kompaktes Steuerungsmenü verwenden</target>
            </trans-unit>
            <trans-unit id="redirectModal.title" resname="redirectModal.title">
                <source>Create Redirects?</source>
                <target>Weiterleitungen erstellen?</target>
            </trans-unit>
            <trans-unit id="redirectModal.message" resname="redirectModal.message">
                <source>You are changing the URL path. Do you want to create a redirect from the old URL to the new one?</source>
                <target>Sie ändern den URL-Pfad. Möchten Sie eine Weiterleitung von der alten URL zur neuen erstellen?</target>
            </trans-unit>
            <trans-unit id="redirectModal.messageRecursive" resname="redirectModal.messageRecursive">
                <source>This will also apply to all child pages whose URLs change as a result.</source>
                <target>Dies gilt auch für alle Unterseiten, deren URLs sich dadurch ändern.</target>
            </trans-unit>
            <trans-unit id="redirectModal.button.create" resname="redirectModal.button.create">
                <source>Create Redirects</source>
                <target>Weiterleitungen erstellen</target>
            </trans-unit>
            <trans-unit id="redirectModal.button.skip" resname="redirectModal.button.skip">
                <source>Don't Create Redirects</source>
                <target>Keine Weiterleitungen erstellen</target>
            </trans-unit>
            <trans-unit id="redirectModal.button.cancel" resname="redirectModal.button.cancel">
                <source>Cancel</source>
                <target>Abbrechen</target>
            </trans-unit>
            <trans-unit id="placeholder.newPage" resname="placeholder.newPage">
                <source>new-page</source>
                <target>neue-seite</target>
            </trans-unit>
            <trans-unit id="error.lastSegmentOnly.title" resname="error.lastSegmentOnly.title">
                <source>Slug change blocked</source>
                <target>Slug-Änderung blockiert</target>
            </trans-unit>
            <trans-unit id="error.lastSegmentOnly.message" resname="error.lastSegmentOnly.message">
                <source>You can only edit the last segment of the URL slug.</source>
                <target>Sie können nur das letzte Segment des URL-Slugs bearbeiten.</target>
            </trans-unit>
            <trans-unit id="error.hierarchyPermission.title" resname="error.hierarchyPermission.title">
                <source>Slug change blocked</source>
                <target>Slug-Änderung blockiert</target>
            </trans-unit>
            <trans-unit id="error.hierarchyPermission.message" resname="error.hierarchyPermission.message">
                <source>You cannot modify path segments above your permission level.</source>
                <target>Sie können keine Pfadsegmente oberhalb Ihrer Berechtigungsstufe ändern.</target>
            </trans-unit>
            <trans-unit id="error.reservedPath.title" resname="error.reservedPath.title">
                <source>URL path is reserved</source>
                <target>URL-Pfad ist reserviert</target>
            </trans-unit>
            <trans-unit id="error.reservedPath.message" resname="error.reservedPath.message">
                <source>This URL path is reserved and cannot be used. Please choose a different slug.</source>
                <target>Dieser URL-Pfad ist reserviert und kann nicht verwendet werden. Bitte wählen Sie einen anderen Slug.</target>
            </trans-unit>
            <trans-unit id="warning.reservedPath" resname="warning.reservedPath">
                <source>This URL path matches a reserved path and will be rejected on save.</source>
                <target>Dieser URL-Pfad entspricht einem reservierten Pfad und wird beim Speichern abgelehnt.</target>
            </trans-unit>
            <trans-unit id="error.proposalFailed.title" resname="error.proposalFailed.title">
                <source>URL preview unavailable</source>
                <target>URL-Vorschau nicht verfügbar</target>
            </trans-unit>
            <trans-unit id="error.proposalFailed.message" resname="error.proposalFailed.message">
                <source>Could not update the URL preview. Please check your connection and try again.</source>
                <target>Die URL-Vorschau konnte nicht aktualisiert werden. Bitte Verbindung prüfen und erneut versuchen.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.tooltip" resname="prefixMismatch.tooltip">
                <source>This prefix differs from the page hierarchy. Click the regenerate button to update.</source>
                <target>Dieses Präfix weicht von der Seitenhierarchie ab. Klicken Sie auf „Neu generieren", um es zu korrigieren.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.notification.title" resname="prefixMismatch.notification.title">
                <source>URL Path Info</source>
                <target>URL-Pfad-Information</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.notification.message" resname="prefixMismatch.notification.message">
                <source>The URL path prefix doesn't match the page hierarchy. Click the regenerate button to correct it, or ask an administrator for advice.</source>
                <target>Das URL-Pfad-Präfix stimmt nicht mit der Seitenhierarchie überein. Klicken Sie auf „Neu generieren", um es zu korrigieren, oder wenden Sie sich an einen Administrator.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.notification.messageLock" resname="prefixMismatch.notification.messageLock">
                <source>The URL path prefix doesn't match the page hierarchy. Regenerate to correct it, or lock the slug if this is an intentional custom URL.</source>
                <target>Das URL-Pfad-Präfix stimmt nicht mit der Seitenhierarchie überein. Neu generieren, um es zu korrigieren, oder den Slug sperren, wenn dies eine bewusste benutzerdefinierte URL ist.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.note.highlight" resname="prefixMismatch.note.highlight">
                <source>URL prefix doesn't match the page hierarchy.</source>
                <target>URL-Präfix stimmt nicht mit der Seitenhierarchie überein.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.note" resname="prefixMismatch.note">
                <source>If not intentional, use regenerate to correct it.</source>
                <target>Falls nicht beabsichtigt, verwenden Sie „Neu generieren", um es zu korrigieren.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.note.lock" resname="prefixMismatch.note.lock">
                <source>If not intentional, regenerate to fix it — or lock to keep this custom URL.</source>
                <target>Falls nicht beabsichtigt, neu generieren — oder sperren, um diese benutzerdefinierte URL beizubehalten.</target>
            </trans-unit>
            <trans-unit id="prefixMismatch.note.expected" resname="prefixMismatch.note.expected">
                <source>Hierarchy path: %s</source>
                <target>Hierarchie-Pfad: %s</target>
            </trans-unit>
            <trans-unit id="contextMenu.recursiveSlugUpdate" resname="contextMenu.recursiveSlugUpdate">
                <source>Re-apply URL paths recursively</source>
                <target>URL-Pfade rekursiv neu generieren</target>
            </trans-unit>
            <trans-unit id="contextMenu.recursiveSlugUpdate.confirm.title" resname="contextMenu.recursiveSlugUpdate.confirm.title">
                <source>Regenerate URL Paths</source>
                <target>URL-Pfade neu generieren</target>
            </trans-unit>
            <trans-unit id="contextMenu.recursiveSlugUpdate.confirm.message" resname="contextMenu.recursiveSlugUpdate.confirm.message">
                <source>This will regenerate URL paths for all child pages based on their source fields. Continue?</source>
                <target>Die URL-Pfade aller Unterseiten werden anhand ihrer Quellfelder neu generiert. Fortfahren?</target>
            </trans-unit>
            <trans-unit id="contextMenu.recursiveSlugUpdate.button.cancel" resname="contextMenu.recursiveSlugUpdate.button.cancel">
                <source>Cancel</source>
                <target>Abbrechen</target>
            </trans-unit>
            <trans-unit id="contextMenu.recursiveSlugUpdate.success" resname="contextMenu.recursiveSlugUpdate.success">
                <source>URL paths updated successfully.</source>
                <target>URL-Pfade erfolgreich aktualisiert.</target>
            </trans-unit>
        </body>
    </file>
</xliff>
